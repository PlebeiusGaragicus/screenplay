#!/usr/bin/env python3
"""Generate index.html for the screenplay workspace and open it in a browser."""

from __future__ import annotations

import argparse
import html
import re
import webbrowser
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
INDEX_PATH = REPO_ROOT / "index.html"

ORIGINAL_DIR = REPO_ROOT / "story" / "original"
HTML_DIR = REPO_ROOT / "story" / "html"
ADAPTED_DIR = REPO_ROOT / "story" / "adapted"
PROMPTS_DIR = REPO_ROOT / "prompts"

STEPS = [
    ("1", "Convert to HTML", "story/html/<chapter>.html"),
    ("1.1", "Entity manifest", "story/adapted/<chapter>-entities.html"),
    ("1.2", "Entity prompts", "prompts/<slug>/<slug>-base.html"),
    ("2", "Screenplay", "story/adapted/<chapter>-screenplay.html"),
]


@dataclass
class ChapterStatus:
    slug: str
    original: Path | None = None
    source_html: Path | None = None
    entities: Path | None = None
    screenplay: Path | None = None
    create_slugs: list[str] = field(default_factory=list)
    prompt_paths: dict[str, Path] = field(default_factory=dict)

    @property
    def step_done(self) -> dict[str, bool]:
        prompts_done = bool(self.create_slugs) and all(
            slug in self.prompt_paths for slug in self.create_slugs
        )
        return {
            "1": self.source_html is not None,
            "1.1": self.entities is not None,
            "1.2": prompts_done if self.create_slugs else False,
            "2": self.screenplay is not None,
        }

    def next_step(self) -> str | None:
        done = self.step_done
        if not done["1"]:
            return "1"
        if not done["1.1"]:
            return "1.1"
        if self.create_slugs and not done["1.2"]:
            return "1.2"
        if not self.create_slugs and self.entities:
            return "1.2"
        if not done["2"]:
            return "2"
        return None

    def progress_label(self) -> str:
        done = self.step_done
        if done["2"]:
            return "Early pipeline complete"
        nxt = self.next_step()
        if nxt:
            return f"Next: Step {nxt}"
        return "In progress"


def rel_href(path: Path) -> str:
    return html.escape(path.relative_to(REPO_ROOT).as_posix())


def link(path: Path | None, label: str | None = None) -> str:
    if path is None:
        return '<span class="missing">—</span>'
    text = html.escape(label or path.name)
    return f'<a href="{rel_href(path)}">{text}</a>'


def parse_manifest_prompt_slugs(manifest_path: Path) -> list[str]:
    """Collect prompt slugs from linked rows in entity manifest tables."""
    if not manifest_path.exists():
        return []

    text = manifest_path.read_text(encoding="utf-8")
    slugs: list[str] = []

    for match in re.finditer(
        r'<tr id="entity-([^"]+)">(.*?)</tr>',
        text,
        flags=re.IGNORECASE | re.DOTALL,
    ):
        row = match.group(2)
        href_match = re.search(
            r'href="../../prompts/([^"/]+)/\1-base\.html"',
            row,
            flags=re.IGNORECASE,
        )
        if href_match:
            slugs.append(href_match.group(1).strip())
        else:
            slugs.append(match.group(1))

    return slugs


def discover_chapters() -> list[str]:
    slugs: set[str] = set()
    if ORIGINAL_DIR.exists():
        slugs.update(p.stem for p in ORIGINAL_DIR.glob("*.md"))
    if HTML_DIR.exists():
        slugs.update(p.stem for p in HTML_DIR.glob("*.html"))
    if ADAPTED_DIR.exists():
        for path in ADAPTED_DIR.glob("*-entities.html"):
            slugs.add(path.name[: -len("-entities.html")])
        for path in ADAPTED_DIR.glob("*-screenplay.html"):
            slugs.add(path.name[: -len("-screenplay.html")])
    return sorted(slugs)


def build_chapter(slug: str) -> ChapterStatus:
    chapter = ChapterStatus(slug=slug)
    original = ORIGINAL_DIR / f"{slug}.md"
    source_html = HTML_DIR / f"{slug}.html"
    entities = ADAPTED_DIR / f"{slug}-entities.html"
    screenplay = ADAPTED_DIR / f"{slug}-screenplay.html"

    if original.exists():
        chapter.original = original
    if source_html.exists():
        chapter.source_html = source_html
    if entities.exists():
        chapter.entities = entities
        chapter.create_slugs = parse_manifest_prompt_slugs(entities)
    if screenplay.exists():
        chapter.screenplay = screenplay

    for slug_name in chapter.create_slugs:
        prompt_path = PROMPTS_DIR / slug_name / f"{slug_name}-base.html"
        if prompt_path.exists():
            chapter.prompt_paths[slug_name] = prompt_path

    return chapter


def status_badge(done: bool, is_next: bool) -> str:
    if done:
        return '<span class="badge done">done</span>'
    if is_next:
        return '<span class="badge next">next</span>'
    return '<span class="badge pending">pending</span>'


def step_12_artifact(chapter: ChapterStatus) -> str:
    if not chapter.entities:
        return '<span class="muted">Needs manifest (Step 1.1)</span>'
    total = len(chapter.create_slugs)
    if total == 0:
        return link(chapter.entities, "Manifest (no prompt rows)")
    created = len(chapter.prompt_paths)
    summary = f"{created}/{total} prompt pages"
    if chapter.step_done["1.2"]:
        return f"{summary} — {link(chapter.entities, 'manifest')}"
    return (
        f'{summary} — see <a href="{rel_href(chapter.entities)}">manifest</a> for entity list'
    )


def render_chapter_card(chapter: ChapterStatus) -> str:
    done = chapter.step_done
    nxt = chapter.next_step()

    step_files = {
        "1": chapter.source_html,
        "1.1": chapter.entities,
        "2": chapter.screenplay,
    }

    rows = []
    for step_id, step_name, _pattern in STEPS:
        if step_id == "1.2":
            artifact = step_12_artifact(chapter)
        else:
            artifact = link(step_files[step_id])
        rows.append(
            "<tr>"
            f"<td>{status_badge(done[step_id], nxt == step_id)}</td>"
            f"<td><strong>Step {html.escape(step_id)}</strong> — {html.escape(step_name)}</td>"
            f"<td>{artifact}</td>"
            "</tr>"
        )

    quick_links = (
        "<ul class=\"quick-links\">"
        f"<li>{link(chapter.original, 'Markdown original')}</li>"
        f"<li>{link(chapter.source_html, 'Source HTML')}</li>"
        f"<li>{link(chapter.entities, 'Entity manifest')}</li>"
        f"<li>{link(chapter.screenplay, 'Screenplay')}</li>"
        "</ul>"
    )

    return (
        f'<article class="chapter-card" id="chapter-{html.escape(chapter.slug)}">'
        f"<h2>{html.escape(chapter.slug)}</h2>"
        f'<p class="chapter-status">{html.escape(chapter.progress_label())}</p>'
        '<table class="steps"><thead><tr>'
        "<th>Status</th><th>Step</th><th>Artifact</th>"
        "</tr></thead><tbody>"
        + "".join(rows)
        + "</tbody></table>"
        + quick_links
        + "</article>"
    )


def render_file_list(title: str, paths: list[Path], empty: str) -> str:
    if not paths:
        return f"<section><h2>{html.escape(title)}</h2><p class=\"muted\">{html.escape(empty)}</p></section>"
    items = "".join(f"<li>{link(path)}</li>" for path in paths)
    return f"<section><h2>{html.escape(title)}</h2><ul class=\"file-list\">{items}</ul></section>"


