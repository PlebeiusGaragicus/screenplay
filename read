#!/usr/bin/env python3
"""Generate index.html — navigation hub for workspace HTML artifacts."""

from __future__ import annotations

import argparse
import html
import re
import webbrowser
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
INDEX_PATH = REPO_ROOT / "index.html"

MANIFEST = REPO_ROOT / "story" / "adapted" / "entities.html"

PIPELINE_STEPS = """\
  <section class="index-section index-pipeline" id="steps">
    <h2>Pipeline steps</h2>
    <ol>
      <li><strong>Step 1</strong> — Convert to HTML → <code>story/html/&lt;chapter&gt;.html</code></li>
      <li><strong>Step 1.1</strong> — Entity manifest → <code>story/adapted/entities.html</code></li>
      <li><strong>Step 1.2</strong> — Entity prompts → <code>prompts/&lt;slug&gt;/&lt;slug&gt;-base.html</code></li>
      <li><strong>Step 2</strong> — Screenplay → <code>story/adapted/&lt;chapter&gt;-screenplay.html</code></li>
    </ol>
  </section>
"""
TITLE_RE = re.compile(r"<title[^>]*>([^<]+)</title>", re.IGNORECASE)


def rel_href(path: Path) -> str:
    return html.escape(path.relative_to(REPO_ROOT).as_posix())


def link(path: Path, label: str | None = None) -> str:
    text = html.escape(label or path.name)
    return f'<a href="{rel_href(path)}">{text}</a>'


def page_title(path: Path) -> str | None:
    if not path.is_file():
        return None
    head = path.read_text(encoding="utf-8", errors="replace")[:8192]
    match = TITLE_RE.search(head)
    if not match:
        return None
    return match.group(1).strip()


def chapter_sort_key(slug: str) -> tuple[int, str]:
    prefix = slug.split("-", 1)[0]
    if prefix.isdigit():
        return (int(prefix), slug)
    return (999_999, slug)


def chapter_slugs() -> list[str]:
    slugs: set[str] = set()
    html_dir = REPO_ROOT / "story" / "html"
    original_dir = REPO_ROOT / "story" / "original"
    adapted_dir = REPO_ROOT / "story" / "adapted"
    if html_dir.is_dir():
        slugs.update(p.stem for p in html_dir.glob("*.html"))
    if original_dir.is_dir():
        slugs.update(p.stem for p in original_dir.glob("*.md"))
    if adapted_dir.is_dir():
        for path in adapted_dir.glob("*-screenplay.html"):
            slugs.add(path.name[: -len("-screenplay.html")])
    return sorted(slugs, key=chapter_sort_key)


def manifest_entities() -> list[tuple[str, str]]:
    """Entity (slug, display name) rows in manifest table order."""
    if not MANIFEST.is_file():
        return []
    text = MANIFEST.read_text(encoding="utf-8")
    entities: list[tuple[str, str]] = []
    for match in re.finditer(
        r'<tr id="entity-([^"]+)">\s*<td>([^<]+)</td>',
        text,
        flags=re.IGNORECASE,
    ):
        entities.append((match.group(1).strip(), match.group(2).strip()))
    return entities


def render_chapter_cards(slugs: list[str]) -> str:
    if not slugs:
        return '<p class="muted">No chapters yet. Add Markdown under <code>story/original/</code> and run Step 1.</p>'

    cards: list[str] = []
    html_dir = REPO_ROOT / "story" / "html"
    adapted_dir = REPO_ROOT / "story" / "adapted"

    for slug in slugs:
        source = html_dir / f"{slug}.html"
        screenplay = adapted_dir / f"{slug}-screenplay.html"
        title = page_title(source) if source.is_file() else None
        heading = html.escape(title) if title else html.escape(slug)

        links: list[str] = []
        if source.is_file():
            links.append(f"<li>{link(source, 'Source HTML')}</li>")
        if screenplay.is_file():
            links.append(f"<li>{link(screenplay, 'Screenplay')}</li>")
        if not links:
            links.append('<li><span class="muted">No HTML for this chapter yet</span></li>')

        cards.append(
            f'<article class="nav-card">'
            f"<h3>{heading}</h3>"
            f'<p class="slug"><code>{html.escape(slug)}</code></p>'
            f'<ul class="nav-list">{"".join(links)}</ul>'
            "</article>"
        )

    return f'<div class="nav-grid">{"".join(cards)}</div>'


def render_entity_cards(entities: list[tuple[str, str]]) -> str:
    if not entities:
        return '<p class="muted">No entities in the manifest yet.</p>'

    prompts_dir = REPO_ROOT / "prompts"
    cards: list[str] = []
    for slug, name in entities:
        prompt = prompts_dir / slug / f"{slug}-base.html"
        heading = html.escape(name)
        links: list[str] = []
        if prompt.is_file():
            links.append(f"<li>{link(prompt, 'Base prompt')}</li>")
        else:
            links.append('<li><span class="muted">No prompt page yet</span></li>')
        cards.append(
            f'<article class="nav-card">'
            f"<h3>{heading}</h3>"
            f'<p class="slug"><code>{html.escape(slug)}</code></p>'
            f'<ul class="nav-list">{"".join(links)}</ul>'
            "</article>"
        )

    return f'<div class="nav-grid">{"".join(cards)}</div>'


def generate_index() -> str:
    slugs = chapter_slugs()
    entities = manifest_entities()
    generated_at = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    manifest_block = ""
    if MANIFEST.is_file():
        title = page_title(MANIFEST) or "Entity manifest"
        manifest_block = (
            '<section class="index-section" id="manifest">'
            "<h2>Entity manifest</h2>"
            f'<ul class="nav-list"><li>{link(MANIFEST, title)}</li></ul>'
            "</section>"
        )

    entities_section = ""
    if entities:
        entities_section = (
            '<section class="index-section" id="entities">'
            "<h2>Entities</h2>"
            f"{render_entity_cards(entities)}"
            "</section>"
        )

    return f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Screenplay — Navigate</title>
  <link rel="stylesheet" href="assets/screenplay.css">
</head>
<body class="project-index">
  <header class="index-header">
    <h1>Screenplay</h1>
    <p class="meta">Navigation index · generated {html.escape(generated_at)} · <code>./read</code></p>
  </header>

  {PIPELINE_STEPS}

  <section class="index-section" id="chapters">
    <h2>Chapters</h2>
    {render_chapter_cards(slugs)}
  </section>

  {manifest_block}

  {entities_section}

  <footer>
    Regenerate with <code>./read</code> from the repository root.
  </footer>
</body>
</html>
"""


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--no-open",
        action="store_true",
        help="Write index.html without opening a browser.",
    )
    args = parser.parse_args()

    INDEX_PATH.write_text(generate_index(), encoding="utf-8")
    print(f"Wrote {INDEX_PATH.relative_to(REPO_ROOT)}")

    if not args.no_open:
        webbrowser.open(INDEX_PATH.resolve().as_uri())
        print("Opened in browser.")


if __name__ == "__main__":
    main()
