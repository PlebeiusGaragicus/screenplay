#!/usr/bin/env python3
"""Generate index.html for the screenplay workspace and open it in a browser."""

from __future__ import annotations

import argparse
import html
import re
import webbrowser
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent
INDEX_PATH = REPO_ROOT / "index.html"

ORIGINAL_DIR = REPO_ROOT / "story" / "original"
HTML_DIR = REPO_ROOT / "story" / "html"
ADAPTED_DIR = REPO_ROOT / "story" / "adapted"
PROMPTS_DIR = REPO_ROOT / "prompts"
MANIFEST_PATH = ADAPTED_DIR / "entities.html"

STEPS = [
    ("1", "Convert to HTML", "story/html/<chapter>.html"),
    ("1.1", "Entity manifest", "story/adapted/entities.html"),
    ("1.2", "Entity prompts", "prompts/<slug>/<slug>-base.html"),
    ("2", "Screenplay", "story/adapted/<chapter>-screenplay.html"),
]


@dataclass
class ManifestSlice:
    entity_slug: str
    chapter_slug: str
    done: bool


@dataclass
class ProjectStatus:
    manifest_path: Path | None = None
    chapters_scanned: list[str] = field(default_factory=list)
    html_chapters: list[str] = field(default_factory=list)
    entity_slugs: list[str] = field(default_factory=list)
    slices: list[ManifestSlice] = field(default_factory=list)
    names_linked: int = 0

    @property
    def slices_done(self) -> int:
        return sum(1 for s in self.slices if s.done)

    @property
    def slices_total(self) -> int:
        return len(self.slices)

    @property
    def step_11_done(self) -> bool:
        if not self.html_chapters:
            return False
        return set(self.html_chapters) <= set(self.chapters_scanned)

    @property
    def step_12_done(self) -> bool:
        return self.slices_total > 0 and self.slices_done == self.slices_total

    def next_project_step(self) -> str | None:
        if not self.step_11_done and self.html_chapters:
            return "1.1"
        if self.manifest_path and not self.step_12_done and self.slices_total > 0:
            return "1.2"
        if self.manifest_path and not self.step_12_done and self.step_11_done:
            return "1.2"
        return None


@dataclass
class ChapterStatus:
    slug: str
    original: Path | None = None
    source_html: Path | None = None
    screenplay: Path | None = None

    def step_done(self, project: ProjectStatus) -> dict[str, bool]:
        chapter_slices = [s for s in project.slices if s.chapter_slug == self.slug]
        if chapter_slices:
            slices_ok = all(s.done for s in chapter_slices)
        else:
            slices_ok = self.slug in project.chapters_scanned
        return {
            "1": self.source_html is not None,
            "1.1": self.slug in project.chapters_scanned,
            "1.2": slices_ok,
            "2": self.screenplay is not None,
        }

    def next_step(self, project: ProjectStatus) -> str | None:
        done = self.step_done(project)
        if not done["1"]:
            return "1"
        if not done["2"]:
            return "2"
        return None

    def progress_label(self, project: ProjectStatus) -> str:
        done = self.step_done(project)
        if done["2"]:
            return "Screenplay done"
        if not done["1"]:
            return "Next: Step 1"
        if not done["1.1"]:
            return "Not scanned in manifest yet"
        ch_slices = [s for s in project.slices if s.chapter_slug == self.slug]
        if ch_slices and not done["1.2"]:
            n = sum(1 for s in ch_slices if s.done)
            return f"Prompt slices {n}/{len(ch_slices)} for this chapter"
        if done["1.2"] and not done["2"]:
            return "Next: Step 2"
        return "In progress"


def rel_href(path: Path) -> str:
    return html.escape(path.relative_to(REPO_ROOT).as_posix())


def link(path: Path | None, label: str | None = None) -> str:
    if path is None:
        return '<span class="missing">—</span>'
    text = html.escape(label or path.name)
    return f'<a href="{rel_href(path)}">{text}</a>'


def slice_evidence_present(prompt_path: Path, chapter_slug: str) -> bool:
    if not prompt_path.exists():
        return False
    text = prompt_path.read_text(encoding="utf-8")
    marker = f'id="evidence-{chapter_slug}"'
    if marker not in text and f"data-chapter=\"{chapter_slug}\"" not in text:
        return False
    return "<blockquote" in text


def parse_project_manifest() -> ProjectStatus:
    project = ProjectStatus()
    if HTML_DIR.exists():
        project.html_chapters = sorted(p.stem for p in HTML_DIR.glob("*.html"))
    if not MANIFEST_PATH.exists():
        return project

    project.manifest_path = MANIFEST_PATH
    text = MANIFEST_PATH.read_text(encoding="utf-8")

    scanned = re.search(r'data-chapters-scanned="([^"]*)"', text, flags=re.IGNORECASE)
    if scanned:
        raw = scanned.group(1).strip()
        project.chapters_scanned = [s.strip() for s in raw.split(",") if s.strip()]

    for match in re.finditer(
        r'<tr id="entity-([^"]+)">(.*?)</tr>',
        text,
        flags=re.IGNORECASE | re.DOTALL,
    ):
        entity_slug = match.group(1).strip()
        row = match.group(2)
        project.entity_slugs.append(entity_slug)

        if re.search(
            r'href="../../prompts/([^"/]+)/\1-base\.html"',
            row,
            flags=re.IGNORECASE,
        ):
            project.names_linked += 1

        prompt_path = PROMPTS_DIR / entity_slug / f"{entity_slug}-base.html"

        for li_match in re.finditer(
            r"<li\s+([^>]*?)>(.*?)</li>",
            row,
            flags=re.IGNORECASE | re.DOTALL,
        ):
            attrs = li_match.group(1)
            ch_match = re.search(r'data-chapter="([^"]+)"', attrs, flags=re.IGNORECASE)
            if not ch_match:
                continue
            chapter_slug = ch_match.group(1).strip()
            done = 'data-slice-done="true"' in attrs
            if not done:
                done = slice_evidence_present(prompt_path, chapter_slug)
            project.slices.append(
                ManifestSlice(entity_slug, chapter_slug, done)
            )

    return project


def discover_chapters() -> list[str]:
    slugs: set[str] = set()
    if ORIGINAL_DIR.exists():
        slugs.update(p.stem for p in ORIGINAL_DIR.glob("*.md"))
    if HTML_DIR.exists():
        slugs.update(p.stem for p in HTML_DIR.glob("*.html"))
    if ADAPTED_DIR.exists():
        for path in ADAPTED_DIR.glob("*-screenplay.html"):
            slugs.add(path.name[: -len("-screenplay.html")])
    return sorted(slugs)


def build_chapter(slug: str) -> ChapterStatus:
    chapter = ChapterStatus(slug=slug)
    original = ORIGINAL_DIR / f"{slug}.md"
    source_html = HTML_DIR / f"{slug}.html"
    screenplay = ADAPTED_DIR / f"{slug}-screenplay.html"

    if original.exists():
        chapter.original = original
    if source_html.exists():
        chapter.source_html = source_html
    if screenplay.exists():
        chapter.screenplay = screenplay

    return chapter


def status_badge(done: bool, is_next: bool) -> str:
    if done:
        return '<span class="badge done">done</span>'
    if is_next:
        return '<span class="badge next">next</span>'
    return '<span class="badge pending">pending</span>'


def step_11_artifact_chapter(chapter: ChapterStatus, project: ProjectStatus) -> str:
    if chapter.slug in project.chapters_scanned:
        return '<span class="muted">Merged into project manifest</span>'
    if chapter.source_html:
        return '<span class="muted">Not scanned yet — continue Step 1.1</span>'
    return '<span class="missing">—</span>'


def step_12_artifact_chapter(chapter: ChapterStatus, project: ProjectStatus) -> str:
    ch_slices = [s for s in project.slices if s.chapter_slug == chapter.slug]
    if not ch_slices:
        if chapter.slug in project.chapters_scanned:
            return '<span class="muted">No entities in this chapter</span>'
        return '<span class="muted">Scan chapter in Step 1.1 first</span>'
    done = sum(1 for s in ch_slices if s.done)
    return f"{done}/{len(ch_slices)} slices — {link(project.manifest_path, 'manifest')}"


def render_project_card(project: ProjectStatus) -> str:
    nxt = project.next_project_step()
    scanned = len(project.chapters_scanned)
    html_total = len(project.html_chapters)
    scan_summary = f"{scanned}/{html_total} chapters scanned" if html_total else "No source HTML yet"
    slice_summary = (
        f"{project.slices_done}/{project.slices_total} entity×chapter slices"
        if project.slices_total
        else "No entities in manifest"
    )
    names_summary = (
        f"{project.names_linked}/{len(project.entity_slugs)} entities opened"
        if project.entity_slugs
        else "—"
    )

    rows = [
        "<tr>"
        f"<td>{status_badge(project.step_11_done, nxt == '1.1')}</td>"
        "<td><strong>Step 1.1</strong> — Entity manifest (project)</td>"
        f"<td>{scan_summary} — {link(project.manifest_path, 'entities.html')}</td>"
        "</tr>",
        "<tr>"
        f"<td>{status_badge(project.step_12_done, nxt == '1.2')}</td>"
        "<td><strong>Step 1.2</strong> — Entity prompts (project)</td>"
        f"<td>{slice_summary}; {names_summary}</td>"
        "</tr>",
    ]

    label = "Project pipeline"
    if project.step_12_done:
        label += " — early entity phases complete"
    elif nxt:
        label += f" — continue Step {nxt}"

    return (
        '<article class="chapter-card project-card">'
        f"<h2>{html.escape(label)}</h2>"
        '<table class="steps"><thead><tr>'
        "<th>Status</th><th>Step</th><th>Artifact</th>"
        "</tr></thead><tbody>"
        + "".join(rows)
        + "</tbody></table>"
        f'<p class="quick-links"><a href="{rel_href(MANIFEST_PATH)}">Open entity manifest</a></p>'
        "</article>"
    )


def render_chapter_card(chapter: ChapterStatus, project: ProjectStatus) -> str:
    done = chapter.step_done(project)
    nxt = chapter.next_step(project)

    rows = []
    for step_id, step_name, _pattern in STEPS:
        if step_id == "1.1":
            artifact = step_11_artifact_chapter(chapter, project)
        elif step_id == "1.2":
            artifact = step_12_artifact_chapter(chapter, project)
        elif step_id == "1":
            artifact = link(chapter.source_html)
        else:
            artifact = link(chapter.screenplay)
        is_next = nxt == step_id
        rows.append(
            "<tr>"
            f"<td>{status_badge(done[step_id], is_next)}</td>"
            f"<td><strong>Step {html.escape(step_id)}</strong> — {html.escape(step_name)}</td>"
            f"<td>{artifact}</td>"
            "</tr>"
        )

    quick_links = (
        "<ul class=\"quick-links\">"
        f"<li>{link(chapter.original, 'Markdown original')}</li>"
        f"<li>{link(chapter.source_html, 'Source HTML')}</li>"
        f"<li>{link(project.manifest_path, 'Entity manifest')}</li>"
        f"<li>{link(chapter.screenplay, 'Screenplay')}</li>"
        "</ul>"
    )

    return (
        f'<article class="chapter-card" id="chapter-{html.escape(chapter.slug)}">'
        f"<h2>{html.escape(chapter.slug)}</h2>"
        f'<p class="chapter-status">{html.escape(chapter.progress_label(project))}</p>'
        '<table class="steps"><thead><tr>'
        "<th>Status</th><th>Step</th><th>Artifact</th>"
        "</tr></thead><tbody>"
        + "".join(rows)
        + "</tbody></table>"
        + quick_links
        + "</article>"
    )


def render_file_list(title: str, paths: list[Path], empty: str) -> str:
    if not paths:
        return f"<section><h2>{html.escape(title)}</h2><p class=\"muted\">{html.escape(empty)}</p></section>"
    items = "".join(f"<li>{link(path)}</li>" for path in paths)
    return f"<section><h2>{html.escape(title)}</h2><ul class=\"file-list\">{items}</ul></section>"


