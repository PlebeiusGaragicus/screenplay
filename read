def generate_index() -> str:
    project = parse_project_manifest()
    chapters = [build_chapter(slug) for slug in discover_chapters()]
    generated_at = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    project_card = render_project_card(project)
    cards = "".join(render_chapter_card(ch, project) for ch in chapters) or (
        '<p class="muted">No chapters found. Add Markdown under <code>story/original/</code>.</p>'
    )

    originals = sorted(ORIGINAL_DIR.glob("*.md")) if ORIGINAL_DIR.exists() else []
    source_html = sorted(HTML_DIR.glob("*.html")) if HTML_DIR.exists() else []
    adapted = sorted(ADAPTED_DIR.glob("*.html")) if ADAPTED_DIR.exists() else []
    prompts = sorted(PROMPTS_DIR.glob("*/*-base.html")) if PROMPTS_DIR.exists() else []

    return f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Screenplay — Project Index</title>
  <style>{INDEX_STYLES}</style>
</head>
<body>
  <header>
    <h1>Screenplay — Project Index</h1>
    <p class="meta">Generated {html.escape(generated_at)} by <code>./read</code></p>
  </header>

  <section class="pipeline">
    <h2>Early pipeline</h2>
    <p>Human-led steps. Status below is inferred from files on disk.</p>
    <ol>
      <li><strong>Step 1</strong> — Markdown originals → <code>story/html/&lt;chapter&gt;.html</code></li>
      <li><strong>Step 1.1</strong> — Project manifest → <code>story/adapted/entities.html</code> (one chapter per continue)</li>
      <li><strong>Step 1.2</strong> — Entity prompts → <code>prompts/&lt;slug&gt;/&lt;slug&gt;-base.html</code> (one entity×chapter slice per continue)</li>
      <li><strong>Step 2</strong> — Screenplay → <code>story/adapted/&lt;chapter&gt;-screenplay.html</code></li>
    </ol>
  </section>

  <section>
    <h2>Project (Steps 1.1 &amp; 1.2)</h2>
    {project_card}
  </section>

  <section>
    <h2>Chapters</h2>
    {cards}
  </section>

  {render_file_list("All originals", originals, "No Markdown chapters in story/original/.")}
  {render_file_list("All source HTML", source_html, "No converted HTML in story/html/. Run Step 1.")}
  {render_file_list("All adapted HTML", adapted, "No adapted artifacts in story/adapted/.")}
  {render_file_list("All entity prompts", prompts, "No entity prompt pages yet.")}

  <footer>
    Regenerate this page anytime with <code>./read</code> from the repository root.
  </footer>
</body>
</html>
"""


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--no-open",
        action="store_true",
        help="Generate index.html without opening a browser.",
    )
    args = parser.parse_args()

    INDEX_PATH.write_text(generate_index(), encoding="utf-8")
    print(f"Wrote {INDEX_PATH.relative_to(REPO_ROOT)}")

    if not args.no_open:
        webbrowser.open(INDEX_PATH.resolve().as_uri())
        print("Opened in browser.")


if __name__ == "__main__":
    main()
