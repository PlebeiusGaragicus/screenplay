#!/usr/bin/env python3
"""
grok-txt2img — Grok/xAI text-to-image for storyboard panel markdown files.
"""

import os
import sys
from datetime import datetime
from pathlib import Path

import requests

API_URL = "https://api.x.ai/v1/images/generations"
DEFAULT_MODEL = "grok-imagine-image-quality"
DEFAULT_ASPECT = "1:1"
DEFAULT_RESOLUTION = "1k"
TIMEOUT = 120


def load_env():
    env_path = Path.cwd() / ".env"
    if not env_path.exists():
        for parent in Path.cwd().parents:
            if (parent / ".env").exists():
                env_path = parent / ".env"
                break
    if env_path.exists():
        with open(env_path) as f:
            for line in f:
                if line.strip().startswith(("GROK_API_KEY=", "XAI_API_KEY=")):
                    key, val = line.strip().split("=", 1)
                    os.environ[key] = val.strip('"').strip("'")
    return os.getenv("GROK_API_KEY") or os.getenv("XAI_API_KEY")


def parse_panel(panel_path: Path):
    content = panel_path.read_text()
    frontmatter = {}
    prompt_lines = []
    in_fm = False

    for line in content.splitlines():
        if line.strip() == "---":
            in_fm = not in_fm
            continue
        if in_fm:
            if ":" in line:
                k, v = line.split(":", 1)
                frontmatter[k.strip()] = v.strip().strip('"')
        else:
            prompt_lines.append(line)

    prompt = "\n".join(prompt_lines).strip()
    return frontmatter, prompt


def normalize_resolution(value: str) -> str:
    """Map panel frontmatter like 1024x1024 to API-friendly values when needed."""
    v = value.strip().lower()
    if v in ("1k", "2k", "4k"):
        return v
    if "x" in v:
        # grok API uses 1k/2k style; prefer 1k for HD-ish sizes
        return "1k"
    return value


def generate_image(api_key: str, prompt: str, model: str, aspect_ratio: str, resolution: str):
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json",
    }
    payload = {
        "model": model,
        "prompt": prompt,
        "aspect_ratio": aspect_ratio,
        "resolution": resolution,
        "n": 1,
    }
    resp = requests.post(API_URL, headers=headers, json=payload, timeout=TIMEOUT)
    resp.raise_for_status()
    data = resp.json()
    if "data" not in data or not data["data"]:
        raise RuntimeError(f"Unexpected API response: {data}")
    return data["data"][0]["url"]


def download_image(url: str, out_path: Path):
    resp = requests.get(url, timeout=TIMEOUT, stream=True)
    resp.raise_for_status()
    out_path.parent.mkdir(parents=True, exist_ok=True)
    with open(out_path, "wb") as f:
        for chunk in resp.iter_content(8192):
            f.write(chunk)


def main():
    if len(sys.argv) < 2:
        print("Usage: grok-txt2img <panel.md>", file=sys.stderr)
        sys.exit(1)

    panel_file = Path(sys.argv[1]).resolve()
    if not panel_file.exists():
        print(f"Panel file not found: {panel_file}", file=sys.stderr)
        sys.exit(1)

    api_key = load_env()
    if not api_key:
        print("ERROR: GROK_API_KEY (or XAI_API_KEY) not found in .env", file=sys.stderr)
        print("Create .env in project root with: GROK_API_KEY=your-key-here", file=sys.stderr)
        sys.exit(1)

    frontmatter, prompt = parse_panel(panel_file)
    model = frontmatter.get("model", DEFAULT_MODEL)
    aspect = frontmatter.get("aspect_ratio", frontmatter.get("size", DEFAULT_ASPECT))
    resolution = normalize_resolution(
        frontmatter.get("resolution", DEFAULT_RESOLUTION)
    )

    basename = panel_file.stem
    ts = datetime.now().strftime("%Y%m%d-%H%M%S")
    out_path = Path("images/storyboard") / f"{basename}-{ts}.png"

    print("=== grok-txt2img ===")
    print(f"Panel : {panel_file}")
    print(f"Model : {model}")
    print(f"Aspect: {aspect}")
    print(f"Res   : {resolution}")
    print(f"Out   : {out_path}")
    print(f"Prompt:\n{prompt}\n---")

    try:
        url = generate_image(api_key, prompt, model, aspect, resolution)
        print(f"Downloading from {url} ...")
        download_image(url, out_path)
        print(f"Saved: {out_path}")
    except Exception as e:
        print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
